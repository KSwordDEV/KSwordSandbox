{
  "hyperV": {
    "goldenVmName": "KSwordSandbox-Win10-Golden",
    "goldenSnapshotName": "Clean",
    "tempVmPrefix": "KSwordSandbox-Run",
    "switchName": null,
    "useDifferencingDisk": false,
    "baseVhdxPath": null,
    "openVmConsoleOnLiveStart": true,
    "vmConsoleServerName": "localhost",
    "rdpFallbackEnabled": true,
    "rdpTarget": null,
    "memoryStartupBytes": 4294967296
  },
  "guest": {
    "userName": "SandboxUser",
    "passwordSecretName": "KSWORDBOX_GUEST_PASSWORD",
    "workingDirectory": "C:\\KSwordSandbox",
    "agentExecutableName": "KSword.Sandbox.Agent.exe",
    "enablePowerShellDirect": true
  },
  "analysis": {
    "defaultDurationSeconds": 120,
    "maxDurationSeconds": 900,
    "maxSampleBytes": 209715200
  },
  "artifactCollection": {
    "collectDroppedFiles": false,
    "captureScreenshots": false,
    "captureMemoryDumps": false,
    "capturePacketCapture": false
  },
  "paths": {
    "runtimeRoot": "D:\\Temp\\KSwordSandbox",
    "rulesDirectory": "rules",
    "guestPayloadRoot": "D:\\Temp\\KSwordSandbox\\payload\\guest-tools"
  },
  "driver": {
    "enabled": true,
    "serviceName": "KSwordSandboxDriver",
    "hostDriverPath": null,
    "driverPathInGuest": "C:\\KSwordSandbox\\driver\\KSword.Sandbox.Driver.sys",
    "eventJsonLinesPath": "C:\\KSwordSandbox\\out\\driver-events.jsonl",
    "r0CollectorPathInGuest": "C:\\KSwordSandbox\\r0collector\\KSword.Sandbox.R0Collector.exe",
    "devicePath": "\\\\.\\KSwordSandboxDriver",
    "useMockCollector": false
  }
}
