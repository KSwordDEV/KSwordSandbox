{
  "$schema": "https://ksword.local/schemas/package-manifest.v1.json",
  "manifestVersion": 1,
  "packageKind": "source",
  "packageName": "KSwordSandbox-source",
  "description": "Source-release input manifest. It is intentionally source-only and excludes runtime samples, VM state, generated build output, archives, reports, signing material, and local secrets.",
  "releaseContract": {
    "noVmMutationByPackageScript": true,
    "noNetworkPublishByPackageScript": true,
    "noGitPushByPackageScript": true,
    "noDriverSigningByPackageScript": true,
    "guiSigningFallback": "forbidden",
    "legacyCSignToolDefaultPath": "forbidden",
    "runtimePayloadSource": "not applicable; source package is source-only",
    "operatorDiagnostics": "install/run expose read-only Hyper-V prerequisite, VM profile, guest payload, VT key, runtime-root, and RuntimePublishRoot guidance; package-portable.ps1 writes generated metadata and prints stage/archive/safety diagnostics without VM, driver signing, GUI signing fallback, or CSignTool side effects"
  },
  "stagedMetadata": {
    "generatedManifest": "package-manifest.generated.json",
    "contains": [
      "package kind, version, source revision, branch, dirty-state preview",
      "staged file inventory with sizeBytes and sha256 for payload files",
    "safety contract for secrets, VM state, runtime evidence, signing, GUI signing fallback, push/publish, and CSignTool",
      "manifest required checks and optional packaging diagnostics"
    ],
    "selfHashNote": "The generated manifest lists itself in files but omits a recursive self-hash from fileInventory."
  },
  "includePatterns": [
    ".editorconfig",
    ".gitattributes",
    ".gitignore",
    "KSwordSandbox.sln",
    "README.md",
    "install.ps1",
    "run.ps1",
    "config/**",
    "docs/**",
    "driver/**",
    "guest/**",
    "packaging/**",
    "rules/**",
    "scripts/**",
    "src/**",
    "tests/**",
    "tools/**"
  ],
  "excludePatterns": [
    ".agents/**",
    ".cert/**",
    ".git/**",
    ".github/**/artifacts/**",
    ".idea/**",
    ".vs/**",
    ".vscode/**",
