{
  "$schema": "https://ksword.local/schemas/package-manifest.v1.json",
  "manifestVersion": 1,
  "packageKind": "source",
  "packageName": "KSwordSandbox-source",
  "description": "Source-release input manifest. It is intentionally source-only and excludes runtime samples, VM state, generated build output, archives, reports, signing material, and local secrets.",
  "includePatterns": [
    ".editorconfig",
    ".gitattributes",
    ".gitignore",
    "KSwordSandbox.sln",
    "README.md",
    "install.ps1",
    "run.ps1",
    "config/**",
    "docs/**",
    "driver/**",
    "guest/**",
    "packaging/**",
    "rules/**",
    "scripts/**",
    "src/**",
    "tests/**",
    "tools/**"
  ],
  "excludePatterns": [
    ".agents/**",
    ".cert/**",
    ".git/**",
    ".github/**/artifacts/**",
    ".idea/**",
    ".vs/**",
    ".vscode/**",
    "artifacts/**",
    "bin/**",
    "captures/**",
    "coverage/**",
    "logs/**",
    "obj/**",
    "reports/**",
    "runtime/**",
    "samples/**",
    "checkpoints/**",
    "snapshots/**",
    "TestResults/**",
    "vm-state/**",
    "vms/**",
    "virtual-machines/**",
    "x64/**",
    "**/.cert/**",
    "**/.vs/**",
    "**/bin/**",
    "**/obj/**",
    "**/TestResults/**",
    "**/x64/**",
    "scripts/Sign-SandboxDriverWithKsword*.ps1",
    "appsettings.Local.json",
    "sandbox.local.json",
    "secrets.json",
    "user-secrets.json",
    "usersecrets.json",
    "id_rsa",
    "id_dsa",
    "id_ecdsa",
    "id_ed25519",
    "*.local.json",
    "*.secret.json",
    ".env",
    ".env.*",
    "install-state.json",
    "guest-password.dpapi",
    "report.html",
    "report.*.html",
    "report.json",
    "events.json",
    "driver-events.jsonl",
    "*.7z",
    "*.appx",
    "*.avhd",
    "*.avhdx",
    "*.bmp",
    "*.cab",
    "*.cer",
    "*.crt",
    "*.csr",
    "*.der",
    "*.dll",
    "*.dmp",
    "*.doc",
    "*.docx",
    "*.dpapi",
    "*.esd",
    "*.etl",
    "*.evtx",
    "*.exe",
    "*.exp",
    "*.gz",
    "*.ilk",
    "*.iso",
    "*.key",
    "*.kdbx",
    "*.lib",
    "*.log",
    "*.msi",
    "*.msix",
    "*.mrt",
    "*.nvram",
    "*.obj",
    "*.ova",
    "*.ovf",
    "*.p12",
    "*.pcap",
    "*.pcapng",
    "*.pdb",
    "*.pdf",
    "*.pem",
    "*.pfx",
    "*.rar",
    "*.snk",
    "*.sys",
    "*.tar",
    "*.vmcx",
    "*.vmgs",
    "*.vmrs",
    "*.vsv",
    "*.vhd",
    "*.vhdpmem",
    "*.vhdset",
    "*.vhdx",
    "*.wim",
    "*.xls",
    "*.xlsx",
    "*.zip",
    "**/*.7z",
    "**/*.appx",
    "**/*.avhd",
    "**/*.avhdx",
    "**/*.bmp",
    "**/*.cab",
    "**/*.cer",
    "**/*.crt",
    "**/*.csr",
    "**/*.der",
    "**/*.dll",
    "**/*.dmp",
    "**/*.doc",
    "**/*.docx",
    "**/*.dpapi",
    "**/*.esd",
    "**/*.etl",
    "**/*.evtx",
    "**/*.exe",
    "**/*.exp",
    "**/*.gz",
    "**/*.ilk",
    "**/*.iso",
    "**/*.key",
    "**/*.kdbx",
    "**/*.lib",
    "**/*.log",
    "**/*.msi",
    "**/*.msix",
    "**/*.mrt",
    "**/*.nvram",
    "**/*.obj",
    "**/*.ova",
    "**/*.ovf",
    "**/*.p12",
    "**/*.pcap",
    "**/*.pcapng",
    "**/*.pdb",
    "**/*.pdf",
    "**/*.pem",
    "**/*.pfx",
    "**/*.rar",
    "**/*.snk",
    "**/*.sys",
    "**/*.tar",
    "**/*.vmcx",
    "**/*.vmgs",
    "**/*.vmrs",
    "**/*.vsv",
    "**/*.vhd",
    "**/*.vhdpmem",
    "**/*.vhdset",
    "**/*.vhdx",
    "**/*.wim",
    "**/*.xls",
    "**/*.xlsx",
    "**/*.zip"
  ],
  "requiredChecks": [
    "Run scripts/Test-RepositoryPolicy.ps1 before cutting a source package.",
    "Cut source packages from a clean git worktree unless AllowDirtySource is explicitly documented.",
    "Do not include runtime-root folders, submitted samples, VM disks/checkpoints, local state/secrets, build intermediates, signed driver binaries, or private signing material."
  ]
}
