  "requiredChecks": [
    "Published runtime payloads must come from an external RuntimePublishRoot, not from repository bin/obj/x64 folders; use -RequireCompleteRuntimePayloads for runtime handoff builds.",
    "Do not package submitted samples, VM disks/checkpoints, local reports, packet captures, memory dumps, signed driver binaries, or private signing material.",
    "Do not package local state such as sandbox.local.json, install-state.json, guest-password.dpapi, .env files, API keys, or user secret files.",
    "The package script stages and zips locally only; publishing/pushing remains a separate manual release-manager action."
  ],
  "componentProgressTemplate": {
    "schema": "ksword.release.component-progress.v1",
    "purpose": "Machine-readable deployment/productization progress for release reviewers; not fresh live evidence.",
    "components": [
      {
        "id": "runtime-publish-root",
        "handoffGate": "external RuntimePublishRoot; host-web, guest-tools, tools/job-tool, tools/postprocess; no repository bin/obj/x64 fallback",
        "appliesTo": "runtime"
      },
      {
        "id": "package-safety-contract",
        "handoffGate": "exclude samples, reports, VM state, generated artifacts, secrets, signing material, CSignTool"
      },
      {
        "id": "release-smoke-scenarios",
        "handoffGate": "PowerShell parse, repository policy, source StageOnly dry-run; no Hyper-V/live/heavy E2E"
      },
      {
        "id": "fresh-live-guardrail",
        "handoffGate": "fresh live claims require explicit lab job id, commit, runtime root, timestamp, and report paths"
      },
      {
        "id": "operator-remediation-zh",
        "handoffGate": "Chinese next-step remediation is present in readiness/package/install/run output"
      }
    ]
  }
