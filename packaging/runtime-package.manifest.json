{
  "$schema": "https://ksword.local/schemas/package-manifest.v1.json",
  "manifestVersion": 1,
  "packageKind": "runtime",
  "packageName": "KSwordSandbox-portable",
  "description": "Runtime portable-package input manifest. Repository entries are copied from source; published application payloads are copied only from an external RuntimePublishRoot.",
  "releaseContract": {
    "noVmMutationByPackageScript": true,
    "noNetworkPublishByPackageScript": true,
    "noGitPushByPackageScript": true,
    "noDriverSigningByPackageScript": true,
    "guiSigningFallback": "forbidden",
    "legacyCSignToolDefaultPath": "forbidden",
    "completeRuntimePayloadsRequiredForHandoff": true,
    "runtimePayloadSource": "external RuntimePublishRoot only; repository bin/obj/x64 binaries are rejected",
    "operatorDiagnostics": "install/run expose read-only Hyper-V prerequisite, VM profile, guest payload, VT key, runtime-root, and RuntimePublishRoot guidance; optional runtime publish entries are recorded in package-manifest.generated.json when skipped for layout dry-runs, while handoff uses -RequireCompleteRuntimePayloads; generated reviewerChecklist and sourceRuntimeSafetyMetadata identify source/runtime safety boundaries; package/readiness do not use GUI signing fallback or CSignTool",
    "machineReadableComponentProgress": "package-manifest.generated.json:componentProgress and release-readiness.json:componentProgress",
    "reviewerChecklistJson": "package-manifest.generated.json:reviewerChecklist and release-readiness.json:reviewerChecklist",
    "noFreshLiveGuardrail": "package/readiness do not generate fresh live evidence; release notes must say 本候选未刷新 fresh live evidence unless a lab job id is recorded"
  },
  "stagedMetadata": {
    "generatedManifest": "package-manifest.generated.json",
    "contains": [
      "package kind, version, source revision, branch, dirty-state preview",
      "runtime publish root provenance when supplied",
      "staged file inventory with sizeBytes and sha256 for payload files",
      "skipped optional runtime publish entries and remediation context",
      "generated reviewerChecklist for source/runtime handoff, release-note fields, and hard reject conditions",
      "sourceRuntimeSafetyMetadata declaring source-only/source exclusions, external RuntimePublishRoot-only runtime payloads, and non-mutating safety state",
      "safety contract for secrets, VM state, runtime evidence, signing, GUI signing fallback, push/publish, and CSignTool",
      "machine-readable componentProgress snapshot for deployment/productization review",
      "reviewerChecklist JSON and no-fresh-live guardrail fields"
    ],
    "selfHashNote": "The generated manifest lists itself in files but omits a recursive self-hash from fileInventory."
  },
