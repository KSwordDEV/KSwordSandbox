{
  "$schema": "https://ksword.local/schemas/package-manifest.v1.json",
  "manifestVersion": 1,
  "packageKind": "runtime",
  "packageName": "KSwordSandbox-portable",
  "description": "Runtime portable-package input manifest. Repository entries are copied from source; published application payloads are copied only from an external RuntimePublishRoot.",
  "releaseContract": {
    "noVmMutationByPackageScript": true,
    "noNetworkPublishByPackageScript": true,
    "noGitPushByPackageScript": true,
    "noDriverSigningByPackageScript": true,
    "legacyCSignToolDefaultPath": "forbidden",
    "runtimePayloadSource": "external RuntimePublishRoot only; repository bin/obj/x64 binaries are rejected",
    "operatorDiagnostics": "optional runtime publish entries are recorded in package-manifest.generated.json when skipped"
  },
  "stagedMetadata": {
    "generatedManifest": "package-manifest.generated.json",
    "contains": [
      "package kind, version, source revision, branch, dirty-state preview",
      "runtime publish root provenance when supplied",
      "staged file inventory with sizeBytes and sha256 for payload files",
      "skipped optional runtime publish entries and remediation context",
      "safety contract for secrets, VM state, runtime evidence, signing, push/publish, and CSignTool"
    ],
    "selfHashNote": "The generated manifest lists itself in files but omits a recursive self-hash from fileInventory."
  },
  "include": [
    {
      "sourceType": "repository",
      "source": "README.md",
      "target": "README.md",
      "required": true
    },
    {
      "sourceType": "repository",
      "source": "install.ps1",
      "target": "install.ps1",
      "required": true
    },
    {
      "sourceType": "repository",
      "source": "run.ps1",
      "target": "run.ps1",
      "required": true
    },
    {
      "sourceType": "repository",
      "source": "config/sandbox.example.json",
      "target": "config/sandbox.example.json",
      "required": true
    },
    {
      "sourceType": "repository",
      "source": "rules",
      "target": "rules",
      "required": true
    },
    {
      "sourceType": "repository",
      "source": "docs/release.md",
      "target": "docs/release.md",
      "required": true
    },
    {
      "sourceType": "repository",
      "source": "docs/install.md",
      "target": "docs/install.md",
      "required": true
    },
    {
      "sourceType": "repository",
      "source": "docs/run.md",
      "target": "docs/run.md",
      "required": true
    },
    {
      "sourceType": "repository",
      "source": "docs/artifacts.md",
      "target": "docs/artifacts.md",
      "required": true
    },
    {
      "sourceType": "repository",
      "source": "packaging/README.md",
      "target": "packaging/README.md",
      "required": true
    },
    {
      "sourceType": "repository",
      "source": "packaging/runtime-package.manifest.json",
      "target": "packaging/runtime-package.manifest.json",
      "required": true
    },
    {
      "sourceType": "repository",
      "source": "docs/driver-install.md",
      "target": "docs/driver-install.md",
      "required": false
    },
    {
      "sourceType": "repository",
      "source": "docs/driver-signing.md",
      "target": "docs/driver-signing.md",
      "required": false
    },
    {
      "sourceType": "repository",
      "source": "scripts/package-portable.ps1",
      "target": "scripts/package-portable.ps1",
      "required": true
    },
    {
      "sourceType": "repository",
      "source": "scripts/install.ps1",
      "target": "scripts/install.ps1",
      "required": true
    },
    {
      "sourceType": "repository",
      "source": "scripts/run.ps1",
      "target": "scripts/run.ps1",
      "required": true
    },
    {
      "sourceType": "repository",
      "source": "scripts/Manage-SandboxDriver.ps1",
      "target": "scripts/Manage-SandboxDriver.ps1",
      "required": true
    },
    {
      "sourceType": "repository",
      "source": "scripts/Prepare-GuestPayload.ps1",
      "target": "scripts/Prepare-GuestPayload.ps1",
      "required": true
    },
    {
      "sourceType": "repository",
      "source": "scripts/Collect-GuestOutputs.ps1",
      "target": "scripts/Collect-GuestOutputs.ps1",
      "required": true
    },
    {
      "sourceType": "repository",
      "source": "scripts/Import-HyperVJobReport.ps1",
      "target": "scripts/Import-HyperVJobReport.ps1",
      "required": true
    },
    {
      "sourceType": "repository",
      "source": "scripts/Inspect-JobArtifacts.ps1",
      "target": "scripts/Inspect-JobArtifacts.ps1",
      "required": true
    },
    {
      "sourceType": "repository",
      "source": "scripts/Reset-SandboxGuestPassword.ps1",
      "target": "scripts/Reset-SandboxGuestPassword.ps1",
      "required": true
    },
    {
      "sourceType": "repository",
      "source": "scripts/Set-GuestTestSigning.ps1",
      "target": "scripts/Set-GuestTestSigning.ps1",
      "required": false
    },
    {
      "sourceType": "repository",
      "source": "scripts/Start-SandboxHyperVJob.ps1",
      "target": "scripts/Start-SandboxHyperVJob.ps1",
      "required": true
    },
    {
      "sourceType": "repository",
      "source": "scripts/Test-HyperVReadiness.ps1",
      "target": "scripts/Test-HyperVReadiness.ps1",
      "required": true
    },
    {
      "sourceType": "repository",
      "source": "scripts/Test-R0Readiness.ps1",
      "target": "scripts/Test-R0Readiness.ps1",
      "required": false
    },
    {
      "sourceType": "runtimePublish",
      "source": "host-web",
      "target": "app/host-web",
      "required": false,
      "note": "Expected external publish output for KSword.Sandbox.Web."
    },
    {
      "sourceType": "runtimePublish",
      "source": "guest-tools",
      "target": "payload/guest-tools",
      "required": false,
      "note": "Expected external staged guest payload root produced by scripts/Prepare-GuestPayload.ps1 or a release pipeline."
    },
    {
      "sourceType": "runtimePublish",
      "source": "tools/job-tool",
      "target": "tools/job-tool",
      "required": false,
      "note": "Expected external publish output for KSword.Sandbox.JobTool."
    },
    {
      "sourceType": "runtimePublish",
      "source": "tools/postprocess",
      "target": "tools/postprocess",
      "required": false,
      "note": "Expected external publish output for KSword.Sandbox.PostProcess."
    }
  ],
